generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  passwordHash String?
  appleId      String?  @unique
  googleId     String?  @unique
  role         String   @default("user")
  claudeApiKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  nodes                  Node[]
  settings               Setting[]
  usageLedger            UsageLedger[]
  usageSummaries         MonthlyUsageSummary[]
  passwordResetToken     PasswordResetToken?
  pushDevices            PushDevice[]
  notificationSchedule   NotificationSchedule?
  notificationDeliveries NotificationDelivery[]
  grammarCaseStats       GrammarCaseUserStat[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Node {
  id        String   @id @default(uuid())
  userId    String
  parentId  String?
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Node?  @relation("NodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Node[] @relation("NodeTree")
  deck     Deck?

  @@index([userId, parentId])
  @@index([parentId])
}

model Deck {
  nodeId            String    @id
  topic             String
  clarification     String?
  language          String
  explanation       String?
  explanationStatus String    @default("pending")
  grammarCaseStatus String    @default("ready")
  cardCount         Int       @default(10)
  lastStudiedAt     DateTime?
  dueAt             DateTime?
  intervalDays      Float     @default(1)

  node    Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  reviews DeckReview[]
  grammarCases GrammarCase[]
}

model DeckReview {
  id              String   @id @default(uuid())
  deckId          String
  studiedAt       DateTime @default(now())
  eventType       String   @default("review")
  aiStars         Int
  userStars       Int
  aiRecap         String
  intervalApplied Float
  correctCount    Int?
  totalCount      Int?

  deck Deck @relation(fields: [deckId], references: [nodeId], onDelete: Cascade)
}

model GrammarCase {
  id             String   @id @default(uuid())
  deckId         String
  caseKey        String
  label          String
  ruleSummary    String
  generationHint String
  baseWeight     Float    @default(1)
  sourceHash     String
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deck      Deck                  @relation(fields: [deckId], references: [nodeId], onDelete: Cascade)
  userStats GrammarCaseUserStat[]

  @@unique([deckId, caseKey])
  @@index([deckId, active, sortOrder])
  @@index([deckId, sourceHash])
}

model GrammarCaseUserStat {
  userId                  String
  grammarCaseId           String
  seenCount               Int      @default(0)
  correctFirstTryCount    Int      @default(0)
  difficultyMass          Float    @default(0)
  attemptMass             Float    @default(0)
  lastPracticedIteration  Int?
  lastUpdatedIteration    Int?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  grammarCase GrammarCase @relation(fields: [grammarCaseId], references: [id], onDelete: Cascade)

  @@id([userId, grammarCaseId])
  @@index([grammarCaseId])
}

model Setting {
  userId String
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, key])
}

model GlobalConfig {
  key   String @id
  value String
}

model PushDevice {
  id            String    @id @default(uuid())
  userId        String
  expoPushToken String    @unique
  platform      String
  disabledAt    DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, disabledAt])
}

model NotificationSchedule {
  userId           String   @id
  scheduledFor     DateTime
  notificationTime String
  timezone         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduledFor])
}

model NotificationDelivery {
  id           String   @id @default(uuid())
  userId       String
  studyDayKey  String
  dueDeckCount Int
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, studyDayKey])
  @@index([createdAt])
}

model UsageLedger {
  id        String   @id @default(uuid())
  userId    String
  yearMonth String
  source    String // "central" | "own"
  endpoint  String // "cards" | "judge" | "explanation" | "rejection" | "chat"
  model     String
  cost      Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, yearMonth, source])
  @@index([yearMonth, source])
}

model MonthlyUsageSummary {
  userId    String
  yearMonth String
  source    String // "central" | "own"
  totalCost Float  @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, yearMonth, source])
  @@index([yearMonth, source])
}
