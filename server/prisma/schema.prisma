generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  passwordHash String?
  appleId      String?  @unique
  googleId     String?  @unique
  claudeApiKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  nodes          Node[]
  settings       Setting[]
  usageLedger    UsageLedger[]
  usageSummaries MonthlyUsageSummary[]
}

model Node {
  id        String   @id @default(uuid())
  userId    String
  parentId  String?
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Node?  @relation("NodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Node[] @relation("NodeTree")
  deck     Deck?

  @@index([userId, parentId])
  @@index([parentId])
}

model Deck {
  nodeId            String @id
  topic             String
  language          String
  explanation       String?
  explanationStatus String @default("pending")
  cardCount         Int    @default(10)
  lastStudiedAt     DateTime?

  node Node @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model Setting {
  userId String
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, key])
}

model UsageLedger {
  id        String   @id @default(uuid())
  userId    String
  yearMonth String
  source    String   // "central" | "own"
  endpoint  String   // "cards" | "judge" | "explanation" | "rejection" | "chat"
  model     String
  cost      Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, yearMonth, source])
  @@index([yearMonth, source])
}

model MonthlyUsageSummary {
  userId    String
  yearMonth String
  source    String // "central" | "own"
  totalCost Float  @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, yearMonth, source])
  @@index([yearMonth, source])
}
