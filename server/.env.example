DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-random-string"
ENCRYPTION_KEY="change-me-32-byte-hex-key-for-aes256"
PORT=3001

# Optional: for social auth
APPLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""

# Optional: central API key for shared usage
# If set, users can use this key instead of providing their own
CENTRAL_API_KEY=""
CENTRAL_KEY_USER_MONTHLY_LIMIT=2.00
CENTRAL_KEY_GLOBAL_MONTHLY_LIMIT=100.00

# Optional: PostHog analytics, LLM analytics, and error tracking.
# Leave POSTHOG_PROJECT_API_KEY empty or set POSTHOG_ENABLED=0 to disable.
POSTHOG_PROJECT_API_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_ENABLED=0
