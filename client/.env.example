# Host and port of the Express API server.
# Defaults to localhost:3001 if not set.
# Set DEV_SERVER_HOST to your machine's IP when testing on a physical device.
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=3001

# Optional: PostHog analytics/error tracking.
# Leave EXPO_PUBLIC_POSTHOG_KEY empty or set EXPO_PUBLIC_ANALYTICS_ENABLED=0 to disable.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_ANALYTICS_ENABLED=0
