[Unit]
Description=GrammarCrammer API Server
After=network.target

[Service]
Type=simple
User=grammarcrammer
Group=grammarcrammer
WorkingDirectory=/home/grammarcrammer/app/server
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/grammarcrammer/data
PrivateTmp=true

[Install]
WantedBy=multi-user.target
