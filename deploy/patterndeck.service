[Unit]
Description=Pattern Deck API Server
After=network.target

[Service]
Type=simple
User=patterndeck
Group=patterndeck
WorkingDirectory=/home/patterndeck/app/server
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/patterndeck/data
PrivateTmp=true

[Install]
WantedBy=multi-user.target
