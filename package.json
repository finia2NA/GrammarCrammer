{
  "name": "grammarcrammer",
  "private": true,
  "scripts": {
    "server": "pnpm --filter server dev",
    "web": "pnpm --filter client web",
    "start": "pnpm --filter client start",
    "dev": "concurrently -n server,expo -c blue,green \"pnpm server\" \"pnpm start\"",
    "dev:web": "concurrently -n server,expo -c blue,green \"pnpm server\" \"pnpm web\"",
    "dev:ios": "concurrently -n server,expo -c blue,green \"pnpm server\" \"pnpm ios\"",
    "dev:android": "concurrently -n server,expo -c blue,green \"pnpm server\" \"pnpm android\"",
    "ios": "pnpm --filter client ios",
    "android": "pnpm --filter client android",
    "build:server": "pnpm --filter server build",
    "lint": "pnpm --filter client lint",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:generate": "pnpm --filter server db:generate",
    "db:push": "pnpm --filter server db:push",
    "pods": "cd client/ios && pod install",
    "prebuild": "pnpm --filter client prebuild",
    "prebuild:clean": "pnpm --filter client prebuild:clean",
    "xcode": "pnpm prebuild:clean && open client/ios/*.xcworkspace"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
